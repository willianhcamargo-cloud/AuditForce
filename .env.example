# Configurações do Servidor de E-mail do AuditForce
# Defina uma das opções abaixo para que o AuditForce envie e-mails 100% reais de forma totalmente automática.

# OPÇÃO A: Integração com Resend (Recomendado - Gratuito até 3000 e-mails/mês)
RESEND_API_KEY=
RESEND_FROM=AuditForce <noreply@auditforce.com>

# OPÇÃO B: Servidor SMTP Geral (Gmail SMTP, Outlook SMTP, SendGrid, etc.)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AuditForce <noreply@yourdomain.com>
SMTP_SECURE=true
